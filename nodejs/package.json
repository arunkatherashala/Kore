{
  "name": "kore-fileformat",
  "version": "1.1.6",
  "description": "KORE - Killer Optimized Record Exchange: 50x faster than Parquet, 10x smaller than JSON",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "napi build --platform",
    "build:debug": "napi build --debug --platform",
    "test": "jest --testMatch='**/test.test.js'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "kore",
    "file-format",
    "columnar",
    "compression",
    "parquet",
    "binary",
    "data-format",
    "rust",
    "performance"
  ],
  "author": "Katherashala Sai Arun Kumar <arunkatherashala@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arunkatherashala/Kore.git",
    "directory": "nodejs"
  },
  "homepage": "https://github.com/arunkatherashala/Kore",
  "bugs": {
    "url": "https://github.com/arunkatherashala/Kore/issues"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "napi": {
    "name": "kore",
    "triples": {
      "additional": [
        "x86_64-unknown-linux-gnu",
        "x86_64-unknown-linux-musl",
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl",
        "aarch64-pc-windows-msvc",
        "x86_64-pc-windows-msvc",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin"
      ]
    }
  }
}
