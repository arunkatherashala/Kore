fn delta_encode(xs)
{
    if len(xs) == 0 { return [] }
    let prev = xs[0]
    let out = [prev]
    let i = 1
    while i < len(xs)
    {
        let v = xs[i]
        let d = v - prev
        out = concat(out, [d])
        prev = v
        i = i + 1
    }
    return out
}
