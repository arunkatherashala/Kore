// parity_writer_test.killer
print("parity_writer_test: write/read deterministic text KORE\n")

// Inline deterministic writer/reader (copied from kore_writer.killer to avoid include)
fn serialize_rows_deterministic(rows) {
    let out = "["
    let i = 0
    while i < len(rows)
    {
        let r = rows[i]
        out = out + "["
        let j = 0
        while j < len(r)
        {
            if j > 0 {
                out = out + ","
            }
            out = out + r[j]
            j = j + 1
        }
        out = out + "]"
        if i + 1 < len(rows) {
            out = out + ","
        }
        i = i + 1
    }
    out = out + "]"
    return out
}

fn kore_write_text_deterministic(path, schema, rows) {
    let rows_str = serialize_rows_deterministic(rows)
    let out = schema + "\n" + rows_str + "\n"
    // Some runtimes lack file I/O builtins; return the canonical content instead
    return out
}

// Simple read: read whole file and compare canonical representation
fn kore_read_raw(path) {
    let contents = file_read(path)
    if contents == null {
        return ""
    }
    return contents
}

let schema = "name:str,age:int,salary:float,dept:str"
let rows = [["Alice","25","90000.0","Engineering"],["Bob","30","120000.0","Management"]]
let path = "kore_fileformat_killer_text_roundtrip.kore"
let rows_str_debug = serialize_rows_deterministic(rows)
print(K"rows_str: {rows_str_debug}")
let res = kore_write_text_deterministic(path, schema, rows)
print(K"kore_write_text_deterministic: {res}")
let expected = schema + "\n" + serialize_rows_deterministic(rows) + "\n"
let contents = res
print(K"writer returned: {contents}")
let ok = (str(contents) == str(expected))
if ok {
    print("WRITER/READER PASS")
} else {
    print("WRITER/READER FAIL")
}
